/*
 * File: src/main/java/com/alibaba/titansort/core/RunGenerator.java
 */
package com.alibaba.titansort.core;

import com.alibaba.titansort.config.SortConfig;
import com.alibaba.titansort.io.RecordReader;
import com.alibaba.titansort.model.Record;
import com.alibaba.titansort.util.Metrics;
import java.io.*;
import java.nio.charset.StandardCharsets;
import java.util.*;
import java.util.concurrent.CompletableFuture;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;

/**
 * 阶段一：初始分片生成器
 * 读取源文件 -> 内存排序 -> 生成临时有序小文件 (Runs)
 */
public class RunGenerator {

    private final SortConfig config;
    private final ExecutorService sortExecutor;

    public RunGenerator(SortConfig config) {
        this.config = config;
        this.sortExecutor = Executors.newFixedThreadPool(config.getParallelThreads());
    }

    /**
     * 执行分片生成
     * @return 生成的临时文件列表
     */
    public List<File> generateRuns() throws IOException {
        List<File> tempFiles = Collections.synchronizedList(new ArrayList<>());
        List<CompletableFuture<Void>> futures = new ArrayList<>();
        
        try (RecordReader reader = new RecordReader(config.getInputFile(), config.getIoBufferSize())) {
            
            List<Record> buffer = new ArrayList<>();
            long currentSize = 0;
            
            // 估算每条记录大小以控制内存
            long maxBufferBytes = config.getMaxMemoryBytes() / config.getParallelThreads(); 

            Record record;
            while ((record = reader.read()) != null) {
                buffer.add(record);
                currentSize += record.size();

                // 内存达到阈值，触发异步排序并落盘
                if (currentSize >= maxBufferBytes) {
                    final List<Record> chunkSnapshot = new ArrayList<>(buffer);
                    final File tempFile = createTempFile(tempFiles.size());
                    tempFiles.add(tempFile);

                    // 异步提交排序任务
                    CompletableFuture<Void> future = CompletableFuture.runAsync(() -> {
                        sortAndSpill(chunkSnapshot, tempFile);
                    }, sortExecutor);
                    futures.add(future);

                    // 重置缓冲区
                    buffer.clear();
                    currentSize = 0;
                }
            }

            // 处理剩余数据
            if (!buffer.isEmpty()) {
                File tempFile = createTempFile(tempFiles.size());
                tempFiles.add(tempFile);
                sortAndSpill(buffer, tempFile);
            }
        }

        // 等待所有异步任务完成
        CompletableFuture.allOf(futures.toArray(new CompletableFuture[0])).join();
        
        return tempFiles;
    }

    private File createTempFile(int index) {
        return new File(config.getTempDirectory(), "run_" + index + ".tmp");
    }

    /**
     * 内存排序并溢写磁盘 (Spill)
     */
    private void sortAndSpill(List<Record> data, File outputFile) {
        long start = System.currentTimeMillis();
        
        // 1. 内存排序 (使用 TimSort，Java默认)
        Collections.sort(data);
        Metrics.SORT_TIME_MS.addAndGet(System.currentTimeMillis() - start);

        // 2. 顺序写入
        try (BufferedWriter writer = new BufferedWriter(new FileWriter(outputFile), config.getIoBufferSize())) {
            for (Record r : data) {
                writer.write(new String(r.toBytes(), StandardCharsets.UTF_8));
            }
            // Help GC
            data.clear();
        } catch (IOException e) {
            throw new RuntimeException("Failed to spill run to disk: " + outputFile, e);
        }
    }
    
    public void close() {
        sortExecutor.shutdown();
    }
}
5. 核心算法：Phase 2 - K路归并 (K-Way Merge)

这是算法最核心的部分，使用了最小堆 (Min-Heap) 加上生产者-消费者管道优化。

code
Java
download
content_copy
expand_less
/*
 * File: src/main/java/com/alibaba/titansort/core/KWayMerger.java
 */
package com.alibaba.titansort.core;

import com.alibaba.titansort.config.SortConfig;
import com.alibaba.titansort.io.AsyncFileWriter;
import com.alibaba.titansort.io.RecordReader;
import com.alibaba.titansort.model.Record;
import com.alibaba.titansort.util.Metrics;

import java.io.File;
import java.io.IOException;
import java.util.*;

/**
 * 阶段二：K路归并器
 * 使用优先队列（Min-Heap）合并多个有序文件
 */
public class KWayMerger {

    private final SortConfig config;

    public KWayMerger(SortConfig config) {
        this.config = config;
    }

    /**
     * 递归合并
     * 如果临时文件数量 > MergeFactor，则进行多轮合并
     */
    public void merge(List<File> runFiles) throws IOException {
        long start = System.currentTimeMillis();
        
        // 队列化处理 runFiles
        Queue<File> pendingFiles = new LinkedList<>(runFiles);
        
        int pass = 0;
        while (pendingFiles.size() > 1) {
            System.out.println("Merge Pass " + (++pass) + ", remaining files: " + pendingFiles.size());
            
            // 每一轮生成的合并后文件
            List<File> nextLevelFiles = new ArrayList<>();
            
            while (!pendingFiles.isEmpty()) {
                // 取出 K 个文件进行合并
                List<File> batch = new ArrayList<>();
                for (int i = 0; i < config.getMergeFactor() && !pendingFiles.isEmpty(); i++) {
                    batch.add(pendingFiles.poll());
                }

                // 如果是最后一批且只有一个文件，不需要合并，直接放入下一轮
                if (batch.size() == 1) {
                    nextLevelFiles.add(batch.get(0));
                    continue;
                }

                // 确定输出文件 (如果是最后一次合并，直接输出到目标路径)
                File outputFile;
                if (pendingFiles.isEmpty() && nextLevelFiles.isEmpty()) {
                    outputFile = config.getOutputFile();
                } else {
                    outputFile = new File(config.getTempDirectory(), "merge_pass_" + pass + "_" + System.nanoTime() + ".tmp");
                    nextLevelFiles.add(outputFile);
                }

                // 执行单次 K 路合并
                performSingleMerge(batch, outputFile);
                
                // 删除临时文件，释放磁盘空间
                for (File f : batch) {
                    f.delete(); 
                }
            }
            
            // 准备下一轮
            pendingFiles.addAll(nextLevelFiles);
        }
        
        Metrics.MERGE_TIME_MS.addAndGet(System.currentTimeMillis() - start);
    }

    /**
     * 执行一次 K-Way Merge
     * 核心数据结构：PriorityQueue (Min Heap)
     */
    private void performSingleMerge(List<File> inputs, File output) throws IOException {
        // 1. 初始化 Min Heap
        PriorityQueue<MergeElement> minHeap = new PriorityQueue<>(inputs.size());
        List<RecordReader> readers = new ArrayList<>();

        // 2. 初始化输出器 (异步写)
        try (AsyncFileWriter writer = new AsyncFileWriter(output, config.getIoBufferSize())) {
            
            // 3. 打开所有输入流并读取首条记录
            for (File inputFile : inputs) {
                RecordReader reader = new RecordReader(inputFile, config.getIoBufferSize());
                readers.add(reader);
                
                Record head = reader.read();
                if (head != null) {
                    // 将 (记录, 来源Reader索引) 放入堆中
                    minHeap.add(new MergeElement(head, reader));
                }
            }

            // 4. 循环处理堆顶
            while (!minHeap.isEmpty()) {
                // 取出最小值
                MergeElement smallest = minHeap.poll();
                
                // 写入结果
                writer.write(smallest.record);
                
                // 从来源文件补充下一条记录
                Record nextRecord = smallest.sourceReader.read();
                if (nextRecord != null) {
                    // 重用包装对象，减少GC
                    smallest.record = nextRecord; 
                    minHeap.add(smallest);
                }
            }
        } finally {
            // 关闭所有输入流
            for (RecordReader r : readers) {
                try { r.close(); } catch (IOException ignore) {}
            }
        }
    }

    /**
     * 堆元素封装类
     */
    private static class MergeElement implements Comparable<MergeElement> {
        Record record;
        RecordReader sourceReader;

        public MergeElement(Record record, RecordReader sourceReader) {
            this.record = record;
            this.sourceReader = sourceReader;
        }

        @Override
        public int compareTo(MergeElement other) {
            return this.record.compareTo(other.record);
        }
    }
}
6. 主引擎入口 (Engine Main)
code
Java
download
