/*
 * File: src/main/java/com/alibaba/titansort/io/BufferPool.java
 */
package com.alibaba.titansort.io;

import com.alibaba.titansort.exception.TitanSortException;
import java.nio.ByteBuffer;
import java.util.concurrent.ArrayBlockingQueue;
import java.util.concurrent.BlockingQueue;
import java.util.concurrent.TimeUnit;

/**
 * 内存缓冲池
 * 作用：复用 ByteBuffer，减少 Young GC 压力，防止内存碎片化
 */
public class BufferPool {
    
    private final BlockingQueue<ByteBuffer> pool;
    private final int bufferSize;
    private final boolean isDirect;

    public BufferPool(int poolSize, int bufferSize, boolean isDirect) {
        this.bufferSize = bufferSize;
        this.isDirect = isDirect;
        this.pool = new ArrayBlockingQueue<>(poolSize);
        
        for (int i = 0; i < poolSize; i++) {
            ByteBuffer buffer = isDirect ? 
                ByteBuffer.allocateDirect(bufferSize) : 
                ByteBuffer.allocate(bufferSize);
            pool.offer(buffer);
        }
    }

    public ByteBuffer borrowBuffer() {
        try {
            // 阻塞获取，防止内存溢出
            ByteBuffer buffer = pool.poll(5, TimeUnit.SECONDS);
            if (buffer == null) {
                throw new TitanSortException("BufferPool exhausted! Possible memory leak or throughput mismatch.");
            }
            buffer.clear();
            return buffer;
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new TitanSortException("Interrupted while borrowing buffer", e);
        }
    }

    public void returnBuffer(ByteBuffer buffer) {
        if (buffer != null) {
            buffer.clear();
            boolean success = pool.offer(buffer);
            if (!success) {
                // 理论上不应该发生，除非归还了非池化的 Buffer
                System.err.println("Warning: BufferPool full, discarding buffer.");
            }
        }
    }
    
    public int getBufferSize() {
        return bufferSize;
    }
}

/*
 * File: src/main/java/com/alibaba/titansort/io/RecordReader.java
 */
package com.alibaba.titansort.io;

import com.alibaba.titansort.model.Record;
import com.alibaba.titansort.util.Metrics;
import java.io.*;
import java.nio.charset.StandardCharsets;

/**
 * 封装的文件读取器
 * 支持按行读取，未来可扩展为按二进制 Block 读取
 */
public class RecordReader implements Closeable {
    
    private final BufferedReader reader;
    
    public RecordReader(File file, int bufferSize) throws FileNotFoundException {
        long start = System.currentTimeMillis();
        this.reader = new BufferedReader(new FileReader(file), bufferSize);
        Metrics.IO_WAIT_TIME_MS.addAndGet(System.currentTimeMillis() - start);
    }

    public Record read() throws IOException {
        long start = System.currentTimeMillis();
        String line = reader.readLine();
        Metrics.IO_WAIT_TIME_MS.addAndGet(System.currentTimeMillis() - start);
        
        if (line == null) return null;
        
        Metrics.READ_BYTES.addAndGet(line.length());
        return new Record(line);
    }

    @Override
    public void close() throws IOException {
        reader.close();
    }
}

/*
 * File: src/main/java/com/alibaba/titansort/io/AsyncFileWriter.java
 */
package com.alibaba.titansort.io;

import com.alibaba.titansort.model.Record;
import com.alibaba.titansort.util.Metrics;
import java.io.*;
import java.util.concurrent.*;
import java.util.concurrent.atomic.AtomicBoolean;

/**
 * 异步文件写入器 (Producer-Consumer 模型)
 * 作用：将 IO 操作从计算线程中剥离，利用缓冲区实现顺序写 (Sequential Write)
 */
public class AsyncFileWriter implements Closeable {

    private final File outputFile;
    private final BlockingQueue<Record> queue;
    private final ExecutorService executor;
    private final AtomicBoolean isClosed = new AtomicBoolean(false);
    private final CountDownLatch finishLatch = new CountDownLatch(1);
    private volatile Exception ioException = null;

    public AsyncFileWriter(File file, int bufferSize) {
        this.outputFile = file;
        this.queue = new ArrayBlockingQueue<>(10000); // 内部队列
        this.executor = Executors.newSingleThreadExecutor(r -> new Thread(r, "AsyncWriter-" + file.getName()));
        
        // 启动消费者线程
        this.executor.submit(this::processQueue);
    }

    private void processQueue() {
        try (BufferedWriter writer = new BufferedWriter(new FileWriter(outputFile))) {
            while (!isClosed.get() || !queue.isEmpty()) {
                Record record = queue.poll(100, TimeUnit.MILLISECONDS);
                if (record != null) {
                    long start = System.currentTimeMillis();
                    writer.write(new String(record.toBytes(), StandardCharsets.UTF_8));
                    Metrics.IO_WAIT_TIME_MS.addAndGet(System.currentTimeMillis() - start);
                    Metrics.WRITTEN_BYTES.addAndGet(record.size());
                }
            }
        } catch (Exception e) {
            this.ioException = e;
        } finally {
            finishLatch.countDown();
        }
    }

    public void write(Record record) throws IOException {
        if (ioException != null) throw new IOException("Async write failed", ioException);
        try {
            // 背压 (Backpressure): 如果队列满了，生产线程会阻塞
            queue.put(record);
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
            throw new IOException("Interrupted while writing", e);
        }
    }

    @Override
    public void close() throws IOException {
        isClosed.set(true);
        try {
            finishLatch.await(); // 等待队列排空
            executor.shutdownNow();
        } catch (InterruptedException e) {
            Thread.currentThread().interrupt();
        }
        if (ioException != null) throw new IOException("Async write failed during close", ioException);
    }
}
