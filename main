package com.alibaba.titansort.util;

import java.util.concurrent.atomic.AtomicLong;

/**
 * 监控指标收集器
 * 模拟生产环境的 Metrics 系统
 */
public class Metrics {
    public static final AtomicLong READ_BYTES = new AtomicLong(0);
    public static final AtomicLong WRITTEN_BYTES = new AtomicLong(0);
    public static final AtomicLong SORT_TIME_MS = new AtomicLong(0);
    public static final AtomicLong MERGE_TIME_MS = new AtomicLong(0);
    public static final AtomicLong IO_WAIT_TIME_MS = new AtomicLong(0);
    
    public static void printReport() {
        System.out.println("====== TitanSort Performance Report ======");
        System.out.printf("Total Read:    %d MB%n", READ_BYTES.get() / 1024 / 1024);
        System.out.printf("Total Write:   %d MB%n", WRITTEN_BYTES.get() / 1024 / 1024);
        System.out.printf("Sort Phase:    %d ms%n", SORT_TIME_MS.get());
        System.out.printf("Merge Phase:   %d ms%n", MERGE_TIME_MS.get());
        System.out.printf("IO Overhead:   %d ms%n", IO_WAIT_TIME_MS.get());
        System.out.println("==========================================");
    }
    
    public static void reset() {
        READ_BYTES.set(0);
        WRITTEN_BYTES.set(0);
        SORT_TIME_MS.set(0);
        MERGE_TIME_MS.set(0);
        IO_WAIT_TIME_MS.set(0);
    }
}
