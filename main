package com.alibaba.titansort.exception;

/**
 * 排序系统自定义异常基类
 */
public class TitanSortException extends RuntimeException {
    public TitanSortException(String message) {
        super(message);
    }

    public TitanSortException(String message, Throwable cause) {
        super(message, cause);
    }
}

/*
 * File: src/main/java/com/alibaba/titansort/config/SortConfig.java
 */
package com.alibaba.titansort.config;

import java.io.File;

/**
 * 全局排序配置类
 * 采用Builder模式构建，不仅包含路径，还包含底层调优参数
 */
public class SortConfig {
    
    // 默认配置常量
    private static final int DEFAULT_BUFFER_SIZE = 64 * 1024 * 1024; // 64MB
    private static final int DEFAULT_MERGE_FACTOR = 16;              // K路归并的K
    private static final int DEFAULT_THREAD_COUNT = 4;               // 并行排序线程数

    // 核心配置
    private final File inputFile;
    private final File outputFile;
    private final File tempDirectory;
    
    // 调优参数
    private final int maxMemoryBytes;      // 最大可用内存
    private final int ioBufferSize;        // IO Buffer大小
    private final int mergeFactor;         // K路归并因子
    private final int parallelThreads;     // 并行线程数
    private final boolean useDirectBuffer; // 是否使用堆外内存

    private SortConfig(Builder builder) {
        this.inputFile = builder.inputFile;
        this.outputFile = builder.outputFile;
        this.tempDirectory = builder.tempDirectory;
        this.maxMemoryBytes = builder.maxMemoryBytes;
        this.ioBufferSize = builder.ioBufferSize;
        this.mergeFactor = builder.mergeFactor;
        this.parallelThreads = builder.parallelThreads;
        this.useDirectBuffer = builder.useDirectBuffer;
    }

    // Getters...
    public File getInputFile() { return inputFile; }
    public File getOutputFile() { return outputFile; }
    public File getTempDirectory() { return tempDirectory; }
    public int getMaxMemoryBytes() { return maxMemoryBytes; }
    public int getIoBufferSize() { return ioBufferSize; }
    public int getMergeFactor() { return mergeFactor; }
    public int getParallelThreads() { return parallelThreads; }
    public boolean isUseDirectBuffer() { return useDirectBuffer; }

    public static class Builder {
        private File inputFile;
        private File outputFile;
        private File tempDirectory;
        private int maxMemoryBytes = DEFAULT_BUFFER_SIZE;
        private int ioBufferSize = 8 * 1024; // 8KB
        private int mergeFactor = DEFAULT_MERGE_FACTOR;
        private int parallelThreads = DEFAULT_THREAD_COUNT;
        private boolean useDirectBuffer = false;

        public Builder setInputFile(String path) {
            this.inputFile = new File(path);
            return this;
        }

        public Builder setOutputFile(String path) {
            this.outputFile = new File(path);
            return this;
        }

        public Builder setTempDirectory(String path) {
            this.tempDirectory = new File(path);
            return this;
        }

        public Builder setMaxMemoryBytes(int bytes) {
            this.maxMemoryBytes = bytes;
            return this;
        }

        public Builder setMergeFactor(int k) {
            this.mergeFactor = k;
            return this;
        }
        
        public Builder setUseDirectBuffer(boolean enable) {
            this.useDirectBuffer = enable;
            return this;
        }

        public SortConfig build() {
            if (inputFile == null || !inputFile.exists()) {
                throw new IllegalArgumentException("Input file is invalid");
            }
            if (tempDirectory == null) {
                tempDirectory = new File(System.getProperty("java.io.tmpdir"));
            }
            if (!tempDirectory.exists()) {
                tempDirectory.mkdirs();
            }
            return new SortConfig(this);
        }
    }
}
