/*
 * File: src/main/java/com/alibaba/titansort/model/Record.java
 */
package com.alibaba.titansort.model;

import java.nio.ByteBuffer;
import java.nio.charset.StandardCharsets;
import java.util.Arrays;

/**
 * 通用数据记录模型
 * 实现了 Comparable 接口，用于堆排序和归并
 * 
 * 优化点：为了减少对象开销，生产环境可使用 flyweight 模式或直接操作 byte[]
 * 这里为了代码可读性，使用对象封装
 */
public class Record implements Comparable<Record> {
    
    private final byte[] key;   // 排序键
    private final byte[] value; // 负载数据

    public Record(byte[] key, byte[] value) {
        this.key = key;
        this.value = value;
    }

    public Record(String line) {
        // 假设格式为 "KEY\tVALUE"
        String[] parts = line.split("\t", 2);
        this.key = parts[0].getBytes(StandardCharsets.UTF_8);
        this.value = parts.length > 1 ? parts[1].getBytes(StandardCharsets.UTF_8) : new byte[0];
    }
    
    public byte[] toBytes() {
        // 序列化逻辑：Length(Int) + Key + Length(Int) + Value
        // 此处简化为直接拼接，实际应包含长度头
        ByteBuffer buffer = ByteBuffer.allocate(key.length + value.length + 2);
        buffer.put(key);
        buffer.put((byte)'\t');
        buffer.put(value);
        buffer.put((byte)'\n');
        return buffer.array();
    }

    @Override
    public int compareTo(Record other) {
        // 字典序比较 byte 数组，性能关键路径
        int len1 = this.key.length;
        int len2 = other.key.length;
        int lim = Math.min(len1, len2);
        byte[] v1 = this.key;
        byte[] v2 = other.key;

        for (int k = 0; k < lim; k++) {
            if (v1[k] != v2[k]) {
                return (v1[k] & 0xFF) - (v2[k] & 0xFF);
            }
        }
        return len1 - len2;
    }
    
    public int size() {
        return key.length + value.length;
    }
}

/*
 * File: src/main/java/com/alibaba/titansort/util/Metrics.java
