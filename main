项目结构概览
src/main/java/com/alibaba/titansort/
├── config/
│   └── SortConfig.java          // 配置类
├── core/
│   ├── ExternalSortEngine.java  // 引擎入口
│   ├── RunGenerator.java        // Phase 1: 外部归并排序之-分段排序
│   └── KWayMerger.java          // Phase 2: 外部归并排序之-K路归并
├── io/
│   ├── BufferPool.java          // 内存缓冲池
│   ├── AsyncFileWriter.java     // 异步写入器
│   ├── RecordReader.java        // 记录读取器
│   └── RecordWriter.java        // 记录写入器
├── model/
│   └── Record.java              // 数据模型（支持自定义比较器）
├── util/
│   ├── IOUtils.java             // 工具类
│   └── Metrics.java             // 监控指标
└── exception/
    └── TitanSortException.java  // 自定义异常
