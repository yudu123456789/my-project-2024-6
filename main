/*
 * File: src/main/java/com/alibaba/titansort/core/ExternalSortEngine.java
 */
package com.alibaba.titansort.core;

import com.alibaba.titansort.config.SortConfig;
import com.alibaba.titansort.exception.TitanSortException;
import com.alibaba.titansort.util.Metrics;

import java.io.File;
import java.io.IOException;
import java.util.List;
import java.util.concurrent.TimeUnit;

/**
 * TitanSort 引擎入口
 * 负责编排排序的整个生命周期
 */
public class ExternalSortEngine {

    private final SortConfig config;

    public ExternalSortEngine(SortConfig config) {
        this.config = config;
    }

    public void run() {
        System.out.println("Starting TitanSort Engine...");
        System.out.println("Config: " + "Mem=" + config.getMaxMemoryBytes() + ", Threads=" + config.getParallelThreads());
        
        long startTime = System.nanoTime();
        Metrics.reset();

        RunGenerator generator = new RunGenerator(config);
        KWayMerger merger = new KWayMerger(config);

        try {
            // Phase 1: Run Generation
            System.out.println(">>> Phase 1: Generating sorted runs...");
            List<File> runs = generator.generateRuns();
            System.out.println("Generated " + runs.size() + " run files.");

            // Phase 2: Merge
            System.out.println(">>> Phase 2: Merging runs...");
            merger.merge(runs);
            
            System.out.println("Sort completed successfully.");

        } catch (IOException e) {
            throw new TitanSortException("IO Failure during sort", e);
        } catch (Exception e) {
            throw new TitanSortException("Unexpected failure", e);
        } finally {
            // Cleanup
            generator.close();
            cleanupTempFiles();
            Metrics.printReport();
            
            long duration = TimeUnit.NANOSECONDS.toMillis(System.nanoTime() - startTime);
            System.out.println("Total Duration: " + duration + " ms");
        }
    }

    private void cleanupTempFiles() {
        // 简单清理逻辑，删除临时目录下的残留文件
        File tmpDir = config.getTempDirectory();
        if (tmpDir.exists() && tmpDir.isDirectory()) {
            File[] files = tmpDir.listFiles((dir, name) -> name.endsWith(".tmp"));
            if (files != null) {
                for (File f : files) {
                    f.delete();
                }
            }
        }
    }
    
    // --- Main 方法 (模拟调用) ---
    public static void main(String[] args) {
        // 模拟 2GB 内存限制，处理大文件
        SortConfig config = new SortConfig.Builder()
                .setInputFile("./data/large_input.txt")
                .setOutputFile("./data/sorted_output.txt")
                .setTempDirectory("./data/tmp")
                .setMaxMemoryBytes(1024 * 1024 * 512) // 512MB Buffer
                .setMergeFactor(16)                   // 16路归并
                .setParallelThreads(4)                // 4线程
                .setUseDirectBuffer(true)             // 启用堆外内存
                .build();

        ExternalSortEngine engine = new ExternalSortEngine(config);
        engine.run();
    }
}
7. 测试模块 (Unit Tests)

为了体现“Competitive”，必须包含测试代码。这里模拟了数据生成和正确性校验。

