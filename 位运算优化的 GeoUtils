package com.alibaba.interview.util;

import java.awt.geom.Path2D;

public class GeoUtils {

    /**
     * 高性能射线法判断
     * 使用 Path2D (基于 C++底层优化) 或手写纯数学计算
     */
    public static boolean contains(double[][] polygonPoints, double lat, double lon) {
        // 1. 快速 Bounding Box 检查 (AABB Check) - 极低开销过滤 99%
        if (!isInsideBoundingBox(polygonPoints, lat, lon)) return false;

        // 2. 射线法 (Ray Casting)
        boolean result = false;
        for (int i = 0, j = polygonPoints.length - 1; i < polygonPoints.length; j = i++) {
            if ((polygonPoints[i][1] > lon) != (polygonPoints[j][1] > lon) &&
                (lat < (polygonPoints[j][0] - polygonPoints[i][0]) * (lon - polygonPoints[i][1]) / 
                       (polygonPoints[j][1] - polygonPoints[i][1]) + polygonPoints[i][0])) {
                result = !result;
            }
        }
        return result;
    }

